{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended",
    ":separateMajorReleases",
    ":combinePatchMinorReleases",
    ":ignoreUnstable",
    "group:monorepos",
    "group:recommended"
  ],
  "timezone": "Asia/Ho_Chi_Minh",
  "schedule": ["before 8am on monday"],
  "labels": ["dependencies"],
  "assignees": ["tienlx93"],
  "prConcurrentLimit": 10,
  "prHourlyLimit": 2,
  "packageRules": [
    {
      "matchPackageNames": ["node"],
      "matchDepTypes": ["engines"],
      "enabled": false
    },
    {
      "matchPackagePatterns": ["^vue", "^@vue", "vite", "vue-tsc", "eslint", "prettier"],
      "groupName": "Vue & Build Ecosystem",
      "groupSlug": "vue-build-ecosystem"
    },
    {
      "matchPackagePatterns": ["naive-ui", "@vicons"],
      "groupName": "Naive UI Ecosystem",
      "groupSlug": "naive-ui-ecosystem"
    },
    {
      "matchUpdateTypes": ["minor", "patch"],
      "matchCurrentVersion": "!/^0\\./",
      "automerge": true,
      "automergeType": "branch"
    }
  ]
}
